# Top-level env consumed by docker-compose.yml.
# Copy to .env and fill in. .env is gitignored.

# From `supabase status -o env`. Used by the worker to write events/findings via service-role.
SUPABASE_SERVICE_ROLE_KEY=

# LiteLLM model id. Strix uses LiteLLM under the hood.
# Recommended (paid):  openai/gpt-5.4 | anthropic/claude-sonnet-4-6 | vertex_ai/gemini-3-pro-preview
# Recommended (Google AI Studio direct, free tier): gemini/gemini-2.5-pro
STRIX_LLM=gemini/gemini-2.5-pro

# Provider key matching STRIX_LLM. Get from:
#   - Google AI Studio: https://aistudio.google.com/app/apikey
#   - OpenAI: https://platform.openai.com/api-keys
#   - Anthropic: https://console.anthropic.com/
LLM_API_KEY=

# Optional: pin a specific Strix sandbox image (default below).
# STRIX_IMAGE=ghcr.io/usestrix/strix-sandbox:0.1.13
