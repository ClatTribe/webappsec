# Copy to .env for local dev; set via `flyctl secrets set` for production.

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=postgres://postgres:postgres@db.your-project.supabase.co:5432/postgres

# LLM defaults (per-org overrides apply if set in organizations.llm_provider / .llm_api_key_secret_id)
# Default is Gemini Flash — ~10× cheaper than GPT-5.4 or Claude Sonnet
# and produces good-enough reasoning for the typical scan workload.
# Power users override per-org via the settings UI.
STRIX_LLM=gemini/gemini-2.5-flash
LLM_API_KEY=sk-...

# Strix sandbox
STRIX_IMAGE=ghcr.io/usestrix/strix-sandbox:0.1.13
STRIX_BIN=strix

# Agent architecture. The worker defaults to `single-lead` (engine roadmap
# §8.5 Phase 3) for deterministic, version-stable specialist dispatch.
# Set to `legacy` to opt back into the parent-spawns-N pattern; any other
# value (including empty) is treated as legacy by the engine.
# STRIX_AGENT_ARCHITECTURE=single-lead

# Worker behavior
WORKER_CONCURRENCY=1
LOG_LEVEL=INFO
