# Local-dev env. Copy to .env.local and fill in.

# From `supabase start` output:
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service-role key — SERVER ONLY. Never sent to the browser. Lives only in API routes.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitHub OAuth App for the *integration* flow (different from "Login with GitHub" auth).
# Create at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/integrations/oauth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Random 32+ character string used to sign OAuth state tokens.
# Generate via:  openssl rand -hex 32
OAUTH_STATE_SECRET=replace-with-random-32-char-string
